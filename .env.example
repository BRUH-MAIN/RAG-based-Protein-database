# Google AI Studio API key (https://aistudio.google.com/apikey) - used for both
# SQL generation and natural-language answer generation.
GEMINI_API_KEY=

# Read-only Postgres connection string used by the deployed app.
# e.g. postgresql://app_readonly:PASSWORD@HOST/DBNAME?sslmode=require
# See docs/SETUP.md for how to provision this role.
DATABASE_URL=

# Full-privilege Postgres connection string, used ONLY by db/init_db.py and
# the ingest/ scripts. Never used by app.py, never set as an HF Space secret.
INGEST_DATABASE_URL=

# Optional: cap how many UniProt records ingest/parse_and_load.py loads.
INGEST_LIMIT=12000

# Optional: override the Gemini model used for SQL/answer generation.
# Default is gemini-flash-lite-latest - check which models have free-tier
# quota on your account (google.genai Client().models.list()) if this errors.
# GEMINI_MODEL=gemini-flash-lite-latest
